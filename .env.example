# Stripe (server-only secret — never commit real keys)
# Netlify: add these in Site configuration → Environment variables for production,
# deploy-preview, and branch-deploy contexts as needed.
# Create Prices in Dashboard: https://dashboard.stripe.com/test/products
STRIPE_SECRET_KEY=sk_test_...
# Optional alias (not required if STRIPE_SECRET_KEY is set):
# STRIPE_API_KEY=sk_test_...
# Required for full webhook fulfillment. Local: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`.
# Production endpoint: https://YOUR_DOMAIN/api/webhooks/stripe
# Events: checkout.session.completed, checkout.session.async_payment_succeeded,
# checkout.session.async_payment_failed.
STRIPE_WEBHOOK_SECRET=whsec_...

# Public site URL for Checkout redirects (production: https://digni-digital-llc.com)
# On Netlify production, set this explicitly to the canonical domain. Deploy previews
# can fall back to Netlify URL / DEPLOY_PRIME_URL if this is not set.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Price IDs (allowlist) ---
# For sk_test_..., create matching prices in Stripe Test mode and use those test
# price_ IDs here. For sk_live_..., either set live price_ IDs in Netlify env or use
# the committed defaults in config/stripe-price-ids-live.env.
#
# AI Employee: recurring $500/mo + one-time $2000 setup (first invoice together via Checkout)
STRIPE_PRICE_AI_EMPLOYEE_MONTHLY=price_...
STRIPE_PRICE_AI_EMPLOYEE_SETUP=price_...

# Future-Ready — School partnership ($5000/semester one-time, $12000/year recurring)
# Semester: use a one-time Price in Stripe (per term). For auto-renew every 5 months, switch to a recurring Price and change lib/stripe/checkout-plans.ts mode to subscription.
STRIPE_PRICE_FRG_SCHOOL_SEMESTER=price_...
STRIPE_PRICE_FRG_SCHOOL_YEARLY=price_...

# Future-Ready — Guided Learning ($49 one-time)
STRIPE_PRICE_FRG_GUIDED=price_...

# Future-Ready — Professional institutes ($1000 per vocational center)
STRIPE_PRICE_FRG_PROFESSIONAL_MONTHLY=price_...

# Agentic Softwares — project deposit (one-time; default catalog uses $500 — change in Stripe if needed)
STRIPE_PRICE_AGENTIC_DEPOSIT=price_...

# Optional: hide the AI Employee “social planner” TaskQueueDemo block without using the admin toggle.
# (Server-only.) Values: true, 1, yes
# DISABLE_AI_EMPLOYEE_TASK_QUEUE_DEMO=true

# --- DigniGuide chat (OpenRouter) ---
# Get a key: https://openrouter.ai/keys
# Model IDs: https://openrouter.ai/models (e.g. openai/gpt-4o-mini, anthropic/claude-3.5-haiku)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional attribution headers (recommended by OpenRouter)
OPENROUTER_SITE_NAME=Digni Digital

# Admin blog generator still uses OpenAI directly (optional)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Supabase (auth, blog, chat, LMS, admin) ---
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only (never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
